---
/* Inline theme + favicon swap; include once in document <head>. */
---

<link id="dynamic-favicon" rel="icon" type="image/svg+xml" href="/favicon-light.svg" />

<script is:inline>
  function applyTheme() {
    const stored = localStorage.getItem("theme") || "system";
    const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
    const html = document.documentElement;

    html.classList.remove("dark");
    html.removeAttribute("data-theme");

    let effectiveTheme = stored;
    if (stored === "system") {
      effectiveTheme = prefersDark ? "dark" : "light";
    }

    if (effectiveTheme === "dark") {
      html.classList.add("dark");
    } else if (effectiveTheme !== "light") {
      html.setAttribute("data-theme", effectiveTheme);
    }

    const link = document.getElementById("dynamic-favicon");
    if (link) {
      link.href = `/favicon-${effectiveTheme}.svg`;
    }
  }

  applyTheme();

  document.addEventListener("astro:before-swap", (e) => {
    const currentFavicon = document.getElementById("dynamic-favicon");
    const newFavicon = e.newDocument.getElementById("dynamic-favicon");
    if (currentFavicon && newFavicon) {
      newFavicon.href = currentFavicon.href;
    }
  });

  document.addEventListener("astro:after-swap", applyTheme);
</script>
