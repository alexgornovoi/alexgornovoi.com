---
import IconExternalLink from "./icons/IconExternalLink.astro";

export type RelatedLinkItem = {
  label: string;
  url: string;
};

interface Props {
  links: RelatedLinkItem[];
  title?: string;
}

const { links, title = "Related Links" } = Astro.props;
---

{
  links.length > 0 && (
    <section class="mb-8">
      <h2 class="kicker mb-4">{title}</h2>
      <div class="flex flex-wrap gap-3">
        {links.map((link) => (
          <a href={link.url} target="_blank" rel="noopener noreferrer" class="btn btn-outline">
            <IconExternalLink />
            {link.label}
          </a>
        ))}
      </div>
    </section>
  )
}
