---
import type { Role } from "../data/experience";

interface Props {
  role: Role;
}

const { role } = Astro.props;
---

<li class="role-item">
  <a href={`/experience/${role.id}`} class="role-link">
    <div class="space-y-2">
      <div class="space-y-1">
        <h3 class="role-title">{role.title}</h3>
        <p class="role-meta">{role.dates}</p>
      </div>

      {role.description && <p class="role-summary">{role.description}</p>}

      {
        role.highlights && role.highlights.length > 0 && (
          <ul class="role-bullets">
            {role.highlights.map((highlight) => (
              <li>{highlight}</li>
            ))}
          </ul>
        )
      }

      {
        role.technologies && role.technologies.length > 0 && (
          <div class="role-tags">
            {role.technologies.map((tech) => (
              <span class="role-tag">{tech}</span>
            ))}
          </div>
        )
      }
    </div>
  </a>
</li>

<style>
  .role-item {
    position: relative;
  }

  .role-item::before {
    content: "";
    position: absolute;
    left: -28px;
    top: 8px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--surface);
    border: 2px solid var(--accent);
    z-index: 1;
  }

  .role-link {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: 8px 12px;
    margin: -8px -12px;
    border-radius: 8px;
    transition: background 0.15s ease;
  }

  .role-link:hover {
    background: var(--surface-2);
  }

  .role-title {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1.125rem;
    color: var(--text-strong);
    line-height: 1.3;
  }

  .role-meta {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-faint);
    letter-spacing: 0.02em;
  }

  .role-summary {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .role-bullets {
    list-style: disc;
    padding-left: 1.25rem;
    margin: 0;
  }

  .role-bullets li {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin-bottom: 0.25rem;
  }

  .role-bullets li::marker {
    color: var(--text-faint);
  }

  .role-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding-top: 0.5rem;
  }

  .role-tag {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.02em;
    color: var(--text-muted);
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.25rem 0.5rem;
  }
</style>
