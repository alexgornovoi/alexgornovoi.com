---
import "../styles/global.css";
import { ViewTransitions } from "astro:transitions";
import ThemeInit from "../components/ThemeInit.astro";
import SiteFooter from "../components/SiteFooter.astro";

interface Props {
  title?: string;
  description?: string;
  wide?: boolean;
  /** When true, omit sticky site header (e.g. home page). */
  showSiteNav?: boolean;
  /** When true, main is full-width with no vertical padding (sections manage layout). */
  landing?: boolean;
  /** When true, `title` is used as the full document title (no `| Alex Gornovoi` suffix). */
  verbatimTitle?: boolean;
  /** Footer vertical padding utility class. */
  footerPyClass?: string;
}

const {
  title,
  description,
  wide = false,
  showSiteNav = true,
  landing = false,
  verbatimTitle = false,
  footerPyClass = "py-6",
} = Astro.props;

const path = Astro.url.pathname;
const containerClass = wide ? "container-wide" : "container-center";

const navLinks = [
  { href: "/experience", label: "Experience" },
  { href: "/education", label: "Education" },
  { href: "/projects", label: "Projects" },
  { href: "/blog", label: "Blog" },
];

function isActive(href: string) {
  return path.startsWith(href);
}

const documentTitle = title
  ? verbatimTitle
    ? title
    : `${title} | Alex Gornovoi`
  : "Alex Gornovoi";

const mainClass = landing
  ? "flex-1 w-full"
  : `${containerClass} py-8 sm:py-10 pb-16 sm:pb-20 flex-1`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <ThemeInit />
    {description && <meta name="description" content={description} />}
    <title>{documentTitle}</title>
    <ViewTransitions />
    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col" style="background: var(--bg);">
    {
      showSiteNav && (
        <header
          class="sticky top-0 z-50 backdrop-blur-md border-b"
          style="background: color-mix(in srgb, var(--bg) 90%, transparent); border-color: var(--border);"
        >
          <div class:list={[containerClass, "py-3 flex items-center justify-between"]}>
            <a href="/" class="font-mono text-sm font-medium no-link-style" style="color: var(--text-strong);">
              ~/alex.gornovoi
            </a>
            <nav class="flex items-center gap-1">
              {navLinks.map((link) => (
                <a
                  href={link.href}
                  class="px-2.5 py-1.5 text-xs font-mono font-medium rounded-md transition-colors no-link-style"
                  style={
                    isActive(link.href)
                      ? "background: var(--surface-2); color: var(--text-strong);"
                      : "color: var(--text-muted);"
                  }
                >
                  {link.label}
                </a>
              ))}
            </nav>
          </div>
        </header>
      )
    }

    <main class={mainClass}>
      <slot />
    </main>

    <SiteFooter containerClass={containerClass} pyClass={footerPyClass} />
  </body>
</html>
