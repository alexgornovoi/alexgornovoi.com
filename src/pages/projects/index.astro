---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("project")).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---

<BaseLayout title="Projects" wide={true}>
  <div class="animate-fade-up">
    <h1 class="kicker mb-2">Projects</h1>
    <p class="prose-body mb-8">Things I've built and contributed to.</p>
    
    {projects.length === 0 ? (
      <p class="prose-muted">No projects yet.</p>
    ) : (
      <div class="space-y-4">
        {projects.map((p) => (
          <a href={`/projects/${p.id}`} class="card card-interactive block no-link-style">
            <h2 class="h2 mb-1">{p.data.title}</h2>
            <p class="prose-muted">{p.data.description}</p>
          </a>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
