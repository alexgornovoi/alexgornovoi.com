---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import RelatedBlogPosts from "../../components/RelatedBlogPosts.astro";
import IconGithub from "../../components/icons/IconGithub.astro";
import { getCollection, render } from "astro:content";
import { getBlogsForRelation } from "../../utils/blogRelations";

export async function getStaticPaths() {
  const projects = await getCollection("project");
  return projects.map((project) => ({ params: { id: project.id }, props: { project } }));
}

const { id } = Astro.params;
const { project } = Astro.props;
const { Content } = await render(project);
const relatedPosts = await getBlogsForRelation("project", project.id);
---

<BaseLayout title={project.data.title} wide={true}>
  <article class="animate-fade-up">
    <Breadcrumbs
      items={[
        { label: "projects", href: "/projects" },
        { label: id },
      ]}
    />

    <header class="mb-8">
      <h1 class="h1 mb-3">{project.data.title}</h1>
      <p class="prose-body mb-4" style="color: var(--text-muted);">{project.data.description}</p>

      {
        project.data.github && (
          <a
            href={project.data.github}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-outline"
          >
            <IconGithub class="icon-sm" />
            View Source
          </a>
        )
      }
    </header>

    <div class="blog-content">
      <Content />
    </div>

    <RelatedBlogPosts posts={relatedPosts} class="mt-10" />
  </article>
</BaseLayout>
