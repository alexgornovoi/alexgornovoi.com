---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import DetailHero from "../../components/DetailHero.astro";
import KickerSection from "../../components/KickerSection.astro";
import DotBulletList from "../../components/DotBulletList.astro";
import CheckmarkList from "../../components/CheckmarkList.astro";
import TagList from "../../components/TagList.astro";
import RelatedLinks from "../../components/RelatedLinks.astro";
import RelatedBlogPosts from "../../components/RelatedBlogPosts.astro";
import IconBuilding from "../../components/icons/IconBuilding.astro";
import { findRoleById, getAllRoleIds } from "../../data/experience";
import { getBlogsForRelation } from "../../utils/blogRelations";

export function getStaticPaths() {
  return getAllRoleIds().map((id) => ({ params: { id } }));
}

const { id } = Astro.params;
const result = findRoleById(id);

if (!result) {
  return Astro.redirect("/experience");
}

const { company, role } = result;
const relatedPosts = await getBlogsForRelation("experience", role.id);
const metaLine = `${role.dates}${company.location ? ` · ${company.location}` : ""}`;
---

<BaseLayout title={`${role.title} at ${company.company}`} wide={true}>
  <article class="animate-fade-up">
    <Breadcrumbs
      items={[
        { label: "experience", href: "/experience" },
        { label: id },
      ]}
    />

    <DetailHero title={role.title} subtitle={company.company} meta={metaLine}>
      <IconBuilding slot="icon" class="icon-lg" />
    </DetailHero>

    <section class="mb-8">
      <p class="prose-body" style="color: var(--text-muted);">
        {role.longDescription || role.description}
      </p>
    </section>

    {
      role.highlights && role.highlights.length > 0 && (
        <KickerSection title="Key Responsibilities">
          <DotBulletList items={role.highlights} />
        </KickerSection>
      )
    }

    {
      role.achievements && role.achievements.length > 0 && (
        <KickerSection title="Achievements">
          <CheckmarkList items={role.achievements} />
        </KickerSection>
      )
    }

    {
      role.technologies && role.technologies.length > 0 && (
        <KickerSection title="Technologies">
          <TagList tags={role.technologies} />
        </KickerSection>
      )
    }

    <RelatedLinks links={role.links ?? []} />
    <RelatedBlogPosts posts={relatedPosts} />
  </article>
</BaseLayout>
