---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { getCollection, render } from "astro:content";
import { resolveBlogRelatedItem } from "../../utils/blogRelations";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({ params: { id: post.id }, props: { post } }));
}

const { id } = Astro.params;
const { post } = Astro.props;
const { Content } = await render(post);
const relatedItem = await resolveBlogRelatedItem(post);

// Format date nicely
const formattedDate = post.data.pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<BaseLayout title={post.data.title} wide={true}>
  <article class="animate-fade-up">
    <Breadcrumbs items={[
      { label: "blog", href: "/blog" },
      { label: id }
    ]} />
    
    <header class="mb-8">
      <h1 class="h1 mb-3">{post.data.title}</h1>
      <p class="meta">{formattedDate}</p>

      {relatedItem && (
        <section class="mt-6">
          <h2 class="kicker mb-4">Related To</h2>
          <a href={relatedItem.href} class="btn btn-outline">
            <span>{relatedItem.typeLabel}:</span>
            <span>{relatedItem.label}</span>
          </a>
        </section>
      )}
    </header>
    
    <div class="blog-content">
      <Content />
    </div>
  </article>
</BaseLayout>
