---
import BaseLayout from "../layouts/BaseLayout.astro";
import { experience } from "../data/experience";
import { education } from "../data/education";
import { getCollection } from "astro:content";
import IconGithub from "../components/icons/IconGithub.astro";
import IconLinkedIn from "../components/icons/IconLinkedIn.astro";
import IconMail from "../components/icons/IconMail.astro";
import IconBuilding from "../components/icons/IconBuilding.astro";
import EducationCard from "../components/EducationCard.astro";
import TagList from "../components/TagList.astro";

const projects = (await getCollection("project")).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
const featuredProjectIds = ["rulepack", "alexgornovoidotcom"];
const featuredProjects = featuredProjectIds
  .map((id) => projects.find((project) => project.id === id))
  .filter((project): project is (typeof projects)[number] => Boolean(project));

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
const featuredPosts = posts.slice(0, 3);
---

<BaseLayout
  title="Alex Gornovoi | AI Engineer"
  description="Alex Gornovoi - AI Engineer specializing in machine learning, LLMs, and full-stack development."
  wide={true}
  showSiteNav={false}
  landing={true}
  verbatimTitle={true}
  footerPyClass="py-8"
>
  <section class="container-wide pt-12 pb-8 sm:pt-16 sm:pb-10">
    <div class="animate-fade-up">
      <h1 class="h1 mb-3">Alex Gornovoi</h1>
      <p class="text-lg sm:text-xl mb-3 font-mono" style="color: var(--text-muted);">
        AI Engineer @ The Cigna Group
      </p>
      <p class="prose-body max-w-xl mb-6" style="color: var(--text-muted);">
        Currently a AI Engineer at The Cigna Group while pursuing M.S. in Computer Science at Georgia Tech.
        Previously earned B.S. in Computer Science and Computational Mathematics at UMass Amherst.
      </p>

      <div class="flex flex-wrap gap-3">
        <a href="https://github.com/alexgornovoi" target="_blank" rel="noopener noreferrer" class="btn btn-outline">
          <IconGithub class="icon-sm" />
          GitHub
        </a>
        <a
          href="https://www.linkedin.com/in/alexeygornovoi/"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-outline"
        >
          <IconLinkedIn class="icon-sm" />
          LinkedIn
        </a>
        <a href="mailto:alex.gornovoi@gmail.com" class="btn btn-primary">
          <IconMail class="icon-sm" />
          Get in Touch
        </a>
      </div>
    </div>
  </section>

  <section class="container-wide section">
    <div class="animate-fade-up animation-delay-100">
      <div class="flex items-center justify-between mb-4">
        <h2 class="kicker">Experience</h2>
        <a href="/experience" class="meta link">View all →</a>
      </div>

      <div class="space-y-4">
        {experience.slice(0, 1).map((company) => {
          const latestRole = company.roles[0];
          return (
            <a href={`/experience/${latestRole.id}`} class="card card-interactive block no-link-style">
              <div class="flex items-start gap-4">
                <div
                  class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0"
                  style="background: var(--surface-2); color: var(--accent);"
                >
                  <IconBuilding class="icon" />
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex flex-wrap items-baseline gap-x-2 gap-y-1 mb-1">
                    <h3 class="h3">{latestRole.title}</h3>
                    <span class="meta">@ {company.company}</span>
                  </div>
                  <p class="meta mb-2">{latestRole.dates}</p>
                  {latestRole.description && <p class="prose-muted mb-3">{latestRole.description}</p>}
                  {latestRole.technologies && latestRole.technologies.length > 0 && (
                    <TagList tags={latestRole.technologies} />
                  )}
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <section class="container-wide section">
    <div class="animate-fade-up animation-delay-200">
      <div class="flex items-center justify-between mb-4">
        <h2 class="kicker">Education</h2>
        <a href="/education" class="meta link">View all →</a>
      </div>

      <div class="grid sm:grid-cols-2 gap-4">
        {education.map((edu) => (
          <EducationCard edu={edu} size="sm" />
        ))}
      </div>
    </div>
  </section>

  <section class="container-wide section">
    <div class="animate-fade-up animation-delay-300">
      <div class="flex items-center justify-between mb-4">
        <h2 class="kicker">Projects</h2>
        <a href="/projects" class="meta link">View all →</a>
      </div>

      {featuredProjects.length === 0 ? (
        <p class="prose-muted">No projects yet.</p>
      ) : (
        <div
          class:list={[
            "grid gap-4",
            featuredProjects.length <= 2 ? "sm:grid-cols-2" : "sm:grid-cols-2 lg:grid-cols-3",
          ]}
        >
          {featuredProjects.map((project) => (
            <a href={`/projects/${project.id}`} class="card card-interactive block no-link-style">
              <h3 class="h3 mb-2">{project.data.title}</h3>
              <p class="prose-muted">{project.data.description}</p>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <section class="container-wide section mb-16 sm:mb-24">
    <div class="animate-fade-up animation-delay-400">
      <div class="flex items-center justify-between mb-4">
        <h2 class="kicker">Writing</h2>
        <a href="/blog" class="meta link">View all →</a>
      </div>

      {featuredPosts.length === 0 ? (
        <div class="card">
          <p class="prose-muted">No posts yet.</p>
        </div>
      ) : (
        <div class="space-y-3">
          {featuredPosts.map((post) => (
            <a href={`/blog/${post.id}`} class="card card-interactive block no-link-style">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <h3 class="h3 mb-1">{post.data.title}</h3>
                  {post.data.description && <p class="prose-muted">{post.data.description}</p>}
                </div>
                <span class="meta shrink-0">
                  {post.data.pubDate.toLocaleDateString("en-US", { month: "short", year: "numeric" })}
                </span>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
