---
import "../styles/global.css";
import { ViewTransitions } from "astro:transitions";
import { experience } from "../data/experience";
import { education } from "../data/education";
import { getCollection } from "astro:content";
import ThemeSelector from "../components/ThemeSelector.astro";

// Get projects for featured section
const projects = (await getCollection("project")).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
const featuredProjectIds = ["rulepack", "alexgornovoidotcom"];
const featuredProjects = featuredProjectIds
  .map((id) => projects.find((project) => project.id === id))
  .filter((project): project is (typeof projects)[number] => Boolean(project));

// Get blog posts
const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
const featuredPosts = posts.slice(0, 3);

// Get latest role
const currentRole = experience[0]?.roles[0];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    
    <link id="dynamic-favicon" rel="icon" type="image/svg+xml" href="/favicon-light.svg" />
    <meta name="description" content="Alex Gornovoi - AI Engineer specializing in machine learning, LLMs, and full-stack development." />
    
    <!-- Theme initialization -->
    <script is:inline>
      function applyTheme() {
        const stored = localStorage.getItem('theme') || 'system';
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const html = document.documentElement;
        
        // Remove existing theme
        html.classList.remove('dark');
        html.removeAttribute('data-theme');
        
        // Determine effective theme
        let effectiveTheme = stored;
        if (stored === 'system') {
          effectiveTheme = prefersDark ? 'dark' : 'light';
        }
        
        // Apply theme
        if (effectiveTheme === 'dark') {
          html.classList.add('dark');
        } else if (effectiveTheme !== 'light') {
          html.setAttribute('data-theme', effectiveTheme);
        }
        
        // Favicon handling - dark favicon for dark themes
        const link = document.getElementById('dynamic-favicon');
        if (link) {
          const lightThemes = ['light', 'lavender', 'sepia'];
          const isDark = !lightThemes.includes(effectiveTheme);
          link.href = isDark ? '/favicon-dark.svg' : '/favicon-light.svg';
        }
      }
      
      applyTheme();
      document.addEventListener('astro:after-swap', applyTheme);
    </script>
    <title>Alex Gornovoi | AI Engineer</title>
    <ViewTransitions />
  </head>
  <body class="min-h-screen" style="background: var(--bg);">
    <!-- Hero Section -->
    <section class="container-wide pt-12 pb-8 sm:pt-16 sm:pb-10">
      <div class="animate-fade-up">
        <h1 class="h1 mb-3">Alex Gornovoi</h1>
        <p class="text-lg sm:text-xl mb-3 font-mono" style="color: var(--text-muted);">
          AI Engineer @ The Cigna Group
        </p>
        <p class="prose-body max-w-xl mb-6" style="color: var(--text-muted);">
          Currently a AI Engineer at The Cigna Group while pursuing M.S. in Computer Science at Georgia Tech. 
          Previously earned B.S. in Computer Science and Computational Mathematics at UMass Amherst.
        </p>
        
        <!-- Quick Links -->
        <div class="flex flex-wrap gap-3">
          <a href="https://github.com/alexgornovoi" target="_blank" rel="noopener noreferrer" class="btn btn-outline">
            <svg class="icon-sm" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            GitHub
          </a>
          <a href="https://www.linkedin.com/in/alexeygornovoi/" target="_blank" rel="noopener noreferrer" class="btn btn-outline">
            <svg class="icon-sm" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            LinkedIn
          </a>
          <a href="mailto:alex.gornovoi@gmail.com" class="btn btn-primary">
            <svg class="icon-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
            Get in Touch
          </a>
        </div>
      </div>
    </section>

    <!-- Experience Section -->
    <section class="container-wide section">
      <div class="animate-fade-up animation-delay-100">
        <div class="flex items-center justify-between mb-4">
          <h2 class="kicker">Experience</h2>
          <a href="/experience" class="meta link">View all →</a>
        </div>
        
        <div class="space-y-4">
          {experience.slice(0, 1).map((company) => {
            const latestRole = company.roles[0];
            return (
              <a href={`/experience/${latestRole.id}`} class="card card-interactive block no-link-style">
                <div class="flex items-start gap-4">
                  <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0" 
                       style="background: var(--surface-2);">
                    <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.5">
                      <path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                    </svg>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex flex-wrap items-baseline gap-x-2 gap-y-1 mb-1">
                      <h3 class="h3">{latestRole.title}</h3>
                      <span class="meta">@ {company.company}</span>
                    </div>
                    <p class="meta mb-2">{latestRole.dates}</p>
                    {latestRole.description && (
                      <p class="prose-muted mb-3">{latestRole.description}</p>
                    )}
                    {latestRole.technologies && latestRole.technologies.length > 0 && (
                      <div class="flex flex-wrap gap-2">
                        {latestRole.technologies.map((tech) => (
                          <span class="badge">{tech}</span>
                        ))}
                      </div>
                    )}
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Education Section -->
    <section class="container-wide section">
      <div class="animate-fade-up animation-delay-200">
        <div class="flex items-center justify-between mb-4">
          <h2 class="kicker">Education</h2>
          <a href="/education" class="meta link">View all →</a>
        </div>
        
        <div class="grid sm:grid-cols-2 gap-4">
          {education.map((edu, idx) => (
            <a href={`/education/${edu.id}`} class="card card-interactive block no-link-style">
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0"
                     style="background: var(--surface-2);">
                  <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.5">
                    <path d="M12 14l9-5-9-5-9 5 9 5z"/>
                    <path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/>
                    <path d="M12 14l9-5-9-5-9 5 9 5zm0 0v6"/>
                  </svg>
                </div>
                <div class="flex-1 min-w-0">
                  <h3 class="h3 mb-1">{edu.school}</h3>
                  <p class="prose-muted mb-1">{edu.degree}</p>
                  <p class="meta">{edu.dates}</p>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Projects Section -->
    <section class="container-wide section">
      <div class="animate-fade-up animation-delay-300">
        <div class="flex items-center justify-between mb-4">
          <h2 class="kicker">Projects</h2>
          <a href="/projects" class="meta link">View all →</a>
        </div>
        
        {featuredProjects.length === 0 ? (
          <p class="prose-muted">No projects yet.</p>
        ) : (
          <div class={`grid gap-4 ${featuredProjects.length <= 2 ? 'sm:grid-cols-2' : 'sm:grid-cols-2 lg:grid-cols-3'}`}>
            {featuredProjects.map((project) => (
              <a href={`/projects/${project.id}`} class="card card-interactive block no-link-style">
                <h3 class="h3 mb-2">{project.data.title}</h3>
                <p class="prose-muted">{project.data.description}</p>
              </a>
            ))}
          </div>
        )}
      </div>
    </section>

    <!-- Blog Section -->
    <section class="container-wide section mb-16 sm:mb-24">
      <div class="animate-fade-up animation-delay-400">
        <div class="flex items-center justify-between mb-4">
          <h2 class="kicker">Writing</h2>
          <a href="/blog" class="meta link">View all →</a>
        </div>
        
        {featuredPosts.length === 0 ? (
          <div class="card">
            <p class="prose-muted">No posts yet.</p>
          </div>
        ) : (
  <div class="space-y-3">
            {featuredPosts.map((post) => (
              <a href={`/blog/${post.id}`} class="card card-interactive block no-link-style">
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <h3 class="h3 mb-1">{post.data.title}</h3>
                    {post.data.description && <p class="prose-muted">{post.data.description}</p>}
                  </div>
                  <span class="meta flex-shrink-0">
                    {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
                  </span>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>
    </section>

    <!-- Footer -->
    <footer class="border-t" style="border-color: var(--border); background: var(--surface);">
      <div class="container-wide py-8">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
          <p class="meta">© 2025 Alex Gornovoi</p>
          <div class="flex items-center gap-6">
            <a href="https://github.com/alexgornovoi" target="_blank" rel="noopener noreferrer" class="no-link-style" style="color: var(--text-faint);">
              <svg class="icon" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
              </svg>
            </a>
            <a href="https://www.linkedin.com/in/alexeygornovoi/" target="_blank" rel="noopener noreferrer" class="no-link-style" style="color: var(--text-faint);">
              <svg class="icon" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
            <a href="mailto:alex.gornovoi@gmail.com" class="no-link-style" style="color: var(--text-faint);">
              <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </a>
            <!-- Theme Selector -->
            <ThemeSelector />
          </div>
        </div>
  </div>
    </footer>
  </body>
</html>
