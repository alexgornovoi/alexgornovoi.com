---
import BaseLayout from "../layouts/BaseLayout.astro";
import { education } from "../data/education";
---

<BaseLayout title="Education" wide={true}>
  <div class="animate-fade-up">
    <h1 class="kicker mb-2">Education</h1>
    <p class="prose-body mb-8">My academic background and credentials.</p>
    
    <div class="space-y-6">
      {education.map((edu, idx) => (
        <a href={`/education/${edu.id}`} class="card card-interactive block no-link-style">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-lg flex items-center justify-center flex-shrink-0"
                 style="background: var(--surface-2);">
              <svg class="icon-lg" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.5">
                <path d="M12 14l9-5-9-5-9 5 9 5z"/>
                <path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/>
                <path d="M12 14l9-5-9-5-9 5 9 5zm0 0v6"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <h2 class="h2 mb-1">{edu.school}</h2>
              <p class="prose-muted mb-1">{edu.degree}</p>
              <p class="meta">{edu.dates}</p>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
