---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import DetailHero from "../../components/DetailHero.astro";
import KickerSection from "../../components/KickerSection.astro";
import DotBulletList from "../../components/DotBulletList.astro";
import CheckmarkList from "../../components/CheckmarkList.astro";
import RelatedLinks from "../../components/RelatedLinks.astro";
import RelatedBlogPosts from "../../components/RelatedBlogPosts.astro";
import IconGraduationCap from "../../components/icons/IconGraduationCap.astro";
import IconClipboard from "../../components/icons/IconClipboard.astro";
import { findEducationById, getAllEducationIds } from "../../data/education";
import { getBlogsForRelation } from "../../utils/blogRelations";

export function getStaticPaths() {
  return getAllEducationIds().map((id) => ({ params: { id } }));
}

const { id } = Astro.params;
const edu = findEducationById(id);

if (!edu) {
  return Astro.redirect("/education");
}

const relatedPosts = await getBlogsForRelation("education", edu.id);
---

<BaseLayout title={`${edu.degree} - ${edu.school}`} wide={true}>
  <article class="animate-fade-up">
    <Breadcrumbs
      items={[
        { label: "education", href: "/education" },
        { label: id },
      ]}
    />

    <DetailHero title={edu.school} subtitle={edu.degree} meta={edu.dates}>
      <IconGraduationCap slot="icon" class="icon-lg" />
    </DetailHero>

    {
      edu.description && (
        <section class="mb-8">
          <p class="prose-body" style="color: var(--text-muted);">{edu.description}</p>
        </section>
      )
    }

    {
      edu.coursework && edu.coursework.length > 0 && (
        <KickerSection title="Relevant Coursework">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            {edu.coursework.map((course) => (
              <div
                class="flex items-center gap-3 p-3 rounded-lg"
                style="background: var(--surface-2); border: 1px solid var(--border); color: var(--accent);"
              >
                <IconClipboard class="w-4 h-4 shrink-0" />
                <span class="prose-muted">{course}</span>
              </div>
            ))}
          </div>
        </KickerSection>
      )
    }

    {
      edu.achievements && edu.achievements.length > 0 && (
        <KickerSection title="Achievements & Honors">
          <CheckmarkList items={edu.achievements} />
        </KickerSection>
      )
    }

    {
      edu.activities && edu.activities.length > 0 && (
        <KickerSection title="Activities & Involvement">
          <DotBulletList items={edu.activities} />
        </KickerSection>
      )
    }

    <RelatedLinks links={edu.links ?? []} />
    <RelatedBlogPosts posts={relatedPosts} />
  </article>
</BaseLayout>
