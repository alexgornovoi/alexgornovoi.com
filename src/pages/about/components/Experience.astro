---
import { Image } from "astro:assets";
import "../../../styles/global.css";
import Cigna from "@assets/experience/cigna.png";
import Umass from "@assets/experience/umass.png";
import Tools from "@components/Tools.astro";

const experience = [
  {
    logo: Cigna,
    name: "The Cigna Group",
    time: "July, 2024 - Present",
    positions: [
      {
        title: "Artificial Intelligence Engineer",
        time: "July, 2025 - Present",
        description: [
          "Member of the AI Center of Enablement, developing reusable AI capabilities to accelerate enterprise adoption of generative AI.",
          "On the Enterprise Context Model team, enabling knowledge graph creation and querying via content uploads.",
          "Designed and implemented Confluence ingestion pipelines and a simplified ingestion flow to make imports more user-friendly.",
        ],
        tools: [
          "Python",
          "LangChain",
          "LangGraph",
          "RAG",
          "Neo4j",
          "Confluence",
          "OpenAI API",
        ],
      },
      {
        title: "Site Reliability Engineer",
        time: "July, 2024 - July, 2025",
        description: [
          "Improved SRE efficiency through service virtualization, chaos testing, and automation.",
          "Developed a Python package to automate Gremlin chaos tests, integrated into enterprise resiliency pipelines.",
          "Created a reusable virtual service development pattern, streamlining setup steps and improving team productivity.",
          "Partnered with teams to design and deploy virtual services, enhancing reliability testing capabilities.",
          "Assisted teams with FMEA to identify risks and strengthen system resilience.",
        ],
        tools: [
          "Python",
          "Gremlin",
          "Chaos Testing",
          "FMEA",
          "Jenkins",
          "Git",
        ],
      },
      {
        title: "Application Developer Intern",
        time: "May, 2023 - August, 2023",
        description: [
          "Built an end-to-end testing framework using Cypress to improve regression coverage.",
          "Configured CloudBees CI pipelines to automatically trigger tests on code pushes, reducing manual QA effort.",
        ],
        tools: ["JavaScript", "TypeScript", "Cypress", "CI/CD", "CloudBees"],
      },
    ],
  },
  {
    logo: Umass,
    name: "Stockbridge School of Agriculture, UMass Amherst",
    role: "Information Technology Assistant & Desktop Support",
    time: "July, 2022 - May, 2024",
    description: [
      "Provided IT support for faculty, staff, and graduate researchers.",
      "Resolved hardware and software issues, including device troubleshooting and component replacement.",
      "Imaged, configured, and deployed new systems; decommissioned outdated equipment.",
      "Performed installs, updates, and security patches to maintain reliable systems.",
    ],
    tools: ["Computer Provisioning", "Hardware Troubleshooting", "System Administration"],
  },
];
---

{
  experience.map(
    ({ logo, name, role, time, positions, description, tools }, expIndex) => (
      <div
        class="content flex-1 p-5 opacity-0  animate-fade-in-down mb-4"
        style={`animation-delay: ${expIndex * 200}ms;`}
      >
        <div class="flex items-center">
          <div class="w-20 h-20 flex items-center bg-off-white mr-5 rounded-lg">
            <Image alt={name} src={logo} class="w-50" />
          </div>
          <div class="flex flex-col">
            <p class="text-2xl font-bold">{name}</p>
            <p>{role}</p>
            <p class="text-sm">{time}</p>
          </div>
        </div>

        {description && (
          <ul class="my-1 mt-2.5 list-disc ml-4">
            {description.map((desc) => (
              <li class="text-sm">{desc}</li>
            ))}
          </ul>
        )}

        {tools && (
          <div class="flex mt-1.5">
            <Tools tools={tools} />
          </div>
        )}

        {positions && positions.length > 0 && (
          <div class="flex flex-col">
            {positions.map(({ title, time, description, tools }, posIndex) => (
              <div
                class="opacity-0 animate-fade-in-down"
                style={`animation-delay: ${expIndex * 200 + posIndex * 200}ms;`}
              >
                <hr class="my-4 mx-3 h-0.5 border-t-0 dark:bg-off-white/10" />
                <div class="flex flex-col text-justify">
                  <p class="text-xl font-bold">{title}</p>
                  <p class="text-sm my-1">{time}</p>
                  <ul class="my-1 list-disc ml-4">
                    {description.map((desc) => (
                      <li class="text-sm">{desc}</li>
                    ))}
                  </ul>
                  <div class="flex mt-1.5">
                    <Tools tools={tools} />
                  </div>
                </div>
              </div>
            ))}
          </div>
        )}
      </div>
    ),
  )
}

