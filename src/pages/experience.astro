---
import BaseLayout from "../layouts/BaseLayout.astro";
import { experience } from "../data/experience";
---

<BaseLayout title="Experience">
  <div class="leading-tight space-y-3">
    {experience.map((item) => (
      <div class="mb-5">
        <p class="mb-1 font-bold text-lg">{item.company}</p>
        <div class="space-y-2">
          {item.roles.map((role) => (
            <div>
              <p class="mb-0.5">{role.title} · {role.dates}</p>
              {role.meta && <p class="meta">{role.meta}</p>}
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</BaseLayout>
