---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageIntro from "../components/PageIntro.astro";
import ExperienceRoleListItem from "../components/ExperienceRoleListItem.astro";
import IconBuilding from "../components/icons/IconBuilding.astro";
import { experience } from "../data/experience";

const VISIBLE_ROLES = 2;
---

<BaseLayout title="Experience" wide={true}>
  <div class="animate-fade-up">
    <PageIntro
      title="Experience"
      description="My professional journey and the roles I've held."
    />

    <div class="space-y-8">
      {experience.map((company) => {
        const visibleRoles = company.roles.slice(0, VISIBLE_ROLES);
        const hiddenRoles = company.roles.slice(VISIBLE_ROLES);
        const hasHiddenRoles = hiddenRoles.length > 0;

        return (
          <article class="card">
            <header class="flex items-start gap-4 mb-6">
              <div
                class="w-12 h-12 rounded-lg flex items-center justify-center shrink-0"
                style="background: var(--surface-2); color: var(--accent);"
              >
                <IconBuilding class="icon-lg" />
              </div>
              <div>
                <h2 class="h2">{company.company}</h2>
                {company.location && <p class="meta">{company.location}</p>}
              </div>
            </header>

            <div class="roles-timeline">
              <ol class="space-y-6">
                {visibleRoles.map((role) => (
                  <ExperienceRoleListItem role={role} />
                ))}
              </ol>

              {hasHiddenRoles && (
                <details class="mt-6">
                  <summary class="expand-toggle">
                    <span>
                      Show {hiddenRoles.length} more role{hiddenRoles.length > 1 ? "s" : ""}
                    </span>
                    <svg class="expand-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M19 9l-7 7-7-7" />
                    </svg>
                  </summary>

                  <ol class="mt-6 space-y-6">
                    {hiddenRoles.map((role) => (
                      <ExperienceRoleListItem role={role} />
                    ))}
                  </ol>
                </details>
              )}
            </div>
          </article>
        );
      })}
    </div>
  </div>
</BaseLayout>

<style>
  .roles-timeline {
    position: relative;
    padding-left: 28px;
  }

  .roles-timeline::before {
    content: "";
    position: absolute;
    left: 4px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: var(--border);
  }

  .expand-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--link);
    padding: 0.5rem 1rem;
    margin-left: -1rem;
    border-radius: 6px;
    transition:
      color 0.15s ease,
      background 0.15s ease;
    list-style: none;
  }

  .expand-toggle::-webkit-details-marker {
    display: none;
  }

  .expand-toggle:hover {
    color: var(--link-hover);
    background: var(--surface-2);
  }

  .expand-icon {
    width: 1rem;
    height: 1rem;
    transition: transform 0.2s ease;
  }

  details[open] .expand-icon {
    transform: rotate(180deg);
  }

  details[open] .expand-toggle span {
    display: none;
  }

  details[open] .expand-toggle::before {
    content: "Show less";
  }
</style>
